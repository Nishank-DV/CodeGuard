# CodeGuard API Environment Variables

# App Configuration
APP_NAME=CodeGuard API
APP_VERSION=0.4.0
DEBUG=false
LOG_LEVEL=INFO

# Server
HOST=0.0.0.0
PORT=8000

# CORS (Set appropriate origins in production)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Persistence
SQLITE_DB_PATH=./data/codeguard.db

# Request hardening
MAX_CODE_LENGTH=100000
MAX_UPLOAD_BYTES=200000

# Phase 4.1 Auth + RBAC
AUTH_ENABLED=true
AUTH_HEADER_NAME=X-API-Key
AUTH_API_KEYS=admin:dev-admin-key,analyst:dev-analyst-key,viewer:dev-viewer-key

# Database (Placeholder for Phase 2)
# DATABASE_URL=postgresql://user:password@localhost/codeguard

# API Keys (Placeholder for Phase 2)
# OPENAI_API_KEY=sk-your-api-key
# HUGGINGFACE_API_KEY=hf-your-api-key
